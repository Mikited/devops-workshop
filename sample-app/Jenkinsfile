pipeline {
    agent any

    environment {
        IMAGE_NAME = 'devops-workshop-app'
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {
        stage('Build Docker Image') {
            steps {
                // Look for the Dockerfile from the root, and target sample-app as the context
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -f 02-docker/solution/Dockerfile sample-app"
            }
        }

        stage('Smoke Test the Image') {
            steps {
                sh """
                    # 1. Run container normally on default bridge network
                    docker run -d --name smoke-${BUILD_NUMBER} ${IMAGE_NAME}:${IMAGE_TAG}
                    sleep 3
                    
                    # 2. Extract the exact container IP address dynamically
                    CONTAINER_IP=\$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' smoke-${BUILD_NUMBER})
                    echo "Testing connection to container IP: \$CONTAINER_IP"
                    
                    # 3. Test directly against the IP address over internal port 3000
                    if curl -f http://\$CONTAINER_IP:3000/health; then
                        echo "Smoke test passed!"
                        docker stop smoke-${BUILD_NUMBER}
                        docker rm smoke-${BUILD_NUMBER}
                    else
                        echo "Smoke test failed!"
                        docker stop smoke-${BUILD_NUMBER}
                        docker rm smoke-${BUILD_NUMBER}
                        exit 1
                    fi
                """
            }
        }

        stage('Push Image') {
            when {
                branch 'main'
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKERHUB_USER',
                    passwordVariable: 'DOCKERHUB_PASS'
                )]) {
                    sh """
                        echo "\$DOCKERHUB_PASS" | docker login -u "\$DOCKERHUB_USER" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} \$DOCKERHUB_USER/${IMAGE_NAME}:${IMAGE_TAG}
                        docker push \$DOCKERHUB_USER/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "Pipeline failed — check the stage logs above."
        }
        always {
            // Ultimate fallback to ensure port 3100 is freed up
            sh "docker rm -f smoke-${BUILD_NUMBER} || true"
        }
    }
}
