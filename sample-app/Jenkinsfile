pipeline {
    agent any

    environment {
        IMAGE_NAME = 'devops-workshop-app'
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {
        stage('Install and Test') {
            steps {
                sh """
                    cd sample-app
                    npm install
                    npm test
                """
            }
        } // Ends Install and Test stage

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -f 02-docker/solution/Dockerfile sample-app"
            }
        } // Ends Build Docker Image stage
        
        stage('Smoke Test the Image') {
            steps {
                sh """
                    docker run -d --name smoke-${BUILD_NUMBER} ${IMAGE_NAME}:${IMAGE_TAG}
                    sleep 3
                    
                    if docker run --rm --network container:smoke-${BUILD_NUMBER} curlimages/curl:latest -f http://localhost:3000/health; then
                        echo "Smoke test passed!"
                        docker stop smoke-${BUILD_NUMBER}
                        docker rm smoke-${BUILD_NUMBER}
                    else
                        echo "Smoke test failed! Application logs:"
                        docker logs smoke-${BUILD_NUMBER}
                        docker stop smoke-${BUILD_NUMBER}
                        docker rm smoke-${BUILD_NUMBER}
                        exit 1
                    fi
                """
            }
        } // Ends Smoke Test stage

        stage('Push Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh """
                        echo "${DOCKER_PASSWORD}" | docker login -u "${DOCKER_USERNAME}" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${DOCKER_USERNAME}/${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${DOCKER_USERNAME}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        } // Ends Push Image stage
    } // Ends stages block

    post {
        always {
            // Clean up left-over smoke test containers if the build fails early
            sh "docker rm -f smoke-${BUILD_NUMBER} || true"
        }
    } // Ends post block
} // Ends pipeline block
